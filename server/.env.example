PORT=3000

# OpenWeather integration
OPENWEATHER_API_KEY=YOUR_API_KEY_HERE

# MySQL database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=farreach_app
DB_POOL_SIZE=10

# JWT and auth
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
REFRESH_TOKEN_DAYS=30
REFRESH_TOKEN_HASH_SECRET=replace-with-strong-refresh-hash-secret
OTP_SECRET=replace-with-strong-otp-secret
INCLUDE_OTP_IN_RESPONSE=true

# Seeder
SEED_ADMIN_PASSWORD=Admin@12345
