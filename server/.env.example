# ==================== SERVER CONFIGURATION ====================
# PORT: Server port (default: 3000)
PORT=3000

# NODE_ENV: Environment mode (development/production)
NODE_ENV=development

# ==================== DATABASE CONFIGURATION ====================
# MySQL Database connection settings
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=torisom_db

# ==================== JWT CONFIGURATION ====================
# JWT_SECRET: Secret key for signing JWT tokens
# IMPORTANT: Change this to a random, secure value in production!
JWT_SECRET=torisom_secret_key_2024_change_in_production

# ==================== OTP CONFIGURATION ====================
# OTP_EXPIRY_MINUTES: How long OTP codes are valid (in minutes)
OTP_EXPIRY_MINUTES=10

# OTP_TOKEN_EXPIRY_MINUTES: How long verification tokens are valid
OTP_TOKEN_EXPIRY_MINUTES=20

# OTP_RESEND_COOLDOWN_SECONDS: Minimum wait between OTP requests
OTP_RESEND_COOLDOWN_SECONDS=60

# OTP_MAX_SENDS_PER_HOUR: Maximum OTP requests per email per hour
OTP_MAX_SENDS_PER_HOUR=5

# OTP_MAX_VERIFY_ATTEMPTS: Maximum failed OTP verification attempts
OTP_MAX_VERIFY_ATTEMPTS=5

# OTP_VERIFY_WINDOW_MINUTES: Time window for verification attempts
OTP_VERIFY_WINDOW_MINUTES=15

# OTP_VERIFY_BLOCK_MINUTES: How long to block after max attempts exceeded
OTP_VERIFY_BLOCK_MINUTES=15

# ==================== EMAIL CONFIGURATION (Optional) ====================
# Leave empty to use console logging for OTP codes during development
# SMTP_HOST: SMTP server hostname (e.g., smtp.gmail.com)
SMTP_HOST=

# SMTP_PORT: SMTP port (usually 587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP_SECURE: Use TLS/SSL (true/false)
SMTP_SECURE=false

# SMTP_USER: SMTP username/email
SMTP_USER=

# SMTP_PASS: SMTP password (use app-specific password for Gmail)
SMTP_PASS=

# SMTP_FROM: Email address to send from
SMTP_FROM=noreply@tourismapp.com

# ==================== EXTERNAL SERVICES ====================
# OPENWEATHER_API_KEY: OpenWeather API key for weather endpoints
# Get free API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ==================== CORS CONFIGURATION ====================
# API_CORS_ORIGIN: Allowed CORS origin (* for development, specific domain for production)
API_CORS_ORIGIN=*

# ==================== FILE UPLOAD ====================
# MAX_FILE_SIZE: Maximum file upload size in bytes (5MB = 5242880)
MAX_FILE_SIZE=5242880

# ==================== PRODUCTION NOTES ====================
# For production deployment:
# 1. Set NODE_ENV=production
# 2. Change JWT_SECRET to a secure random value
# 3. Configure real database credentials
# 4. Set up proper SMTP for email delivery
# 5. Use HTTPS/SSL certificate
# 6. Restrict CORS_ORIGIN to your domain only
# 7. Set secure database passwords
# 8. Use environment-specific secrets management

